generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  service   String   @default("")
  budget    String   @default("")
  message   String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([read])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String   @default("")
  userAgent String   @default("")
  screen    String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model CaseStudy {
  id          String   @id @default(cuid())
  slug        String   @unique
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)

  // Card-level (homepage + listing)
  client      String
  logo        String   @default("")
  category    String
  title       String
  description String   @default("")
  coverImage  String   @default("")
  metric      String   @default("")
  metricLabel String   @default("")
  tags        String[] @default([])

  // Detail page
  headline    String   @default("")
  subtitle    String   @default("")
  tech        String[] @default([])
  challenge   String   @default("")
  solution    String   @default("")
  videoUrl    String   @default("")

  // JSON fields
  stats       Json     @default("[]")
  gallery     Json     @default("[]")
  features    Json     @default("[]")
  sections    Json     @default("[]")
  results     Json     @default("[]")

  // CTA
  ctaEyebrow  String   @default("")
  ctaHeading  String   @default("")
  ctaAccent   String   @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, sortOrder])
  @@index([slug])
}

model JobPosting {
  id           String           @id @default(cuid())
  title        String
  type         String           // e.g. "Full-time · Remote"
  dept         String           // e.g. "Engineering", "Design"
  desc         String
  published    Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]

  @@index([published])
}

model JobApplication {
  id           String      @id @default(cuid())
  name         String
  email        String
  phone        String?
  linkedin     String?
  resumeUrl    String      // Path to uploaded resume
  coverLetter  String?     @default("")
  jobPostingId String?     // Nullable for spontaneous application
  jobPosting   JobPosting? @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  read         Boolean     @default(false)
  createdAt    DateTime    @default(now())

  @@index([createdAt])
  @@index([read])
}
